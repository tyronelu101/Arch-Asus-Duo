ATTRS{id/vendor}=="0b05", \
ATTRS{id/product}=="1b2d", \
ATTRS{name}=="ASUS Zenbook Duo Keyboard", \
ATTRS{id/bustype}=="0005", \
TAG+="systemd", \
ENV{SYSTEMD_USER_WANTS}="monitor@1.service"
