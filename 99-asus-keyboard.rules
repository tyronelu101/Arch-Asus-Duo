# Keyboard Attached Pogo
ACTION=="add", \
KERNELS=="3-6", \
SUBSYSTEM=="input", \
ATTRS{busnum}=="3", \
ATTRS{devpath}=="6", \
ATTRS{idVendor}=="0b05", \
ATTRS{idProduct}=="1b2c", \
TAG+="systemd", \
ENV{SYSTEMD_USER_WANTS}="monitor@0.service" 
 
# Keyboard Detached Bluetooth
ACTION=="add", \
